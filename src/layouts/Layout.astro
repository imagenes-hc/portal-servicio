---
interface Props {
  title?: string;
}

const { title = "Radioscopias — Portal de Servicio" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-linear-to-br from-blue-950 via-slate-900 to-indigo-950">
    <slot />
  </body>
</html>
