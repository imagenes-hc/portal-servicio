---
import type { NewsItem } from "../lib/fetchNews";

const { source, sourceIcon, title, url, date } = Astro.props as NewsItem;

const formattedDate = new Date(date).toLocaleDateString("es-ES", {
  day: "numeric",
  month: "short",
});
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="flex items-start gap-4 rounded-lg border border-blue-800 bg-blue-900/50 p-4 shadow-sm transition-all duration-200 hover:border-blue-700 hover:bg-blue-900/80 hover:shadow"
>
  <span class="mt-0.5 shrink-0 text-lg">{sourceIcon}</span>
  <div class="min-w-0 flex-1">
    <p class="text-sm font-medium leading-tight text-gray-100 line-clamp-2">
      {title}
    </p>
    <div class="mt-1.5 flex items-center gap-1.5 text-xs text-blue-300">
      <span>{source}</span>
      <span>·</span>
      <time datetime={date}>{formattedDate}</time>
    </div>
  </div>
</a>
