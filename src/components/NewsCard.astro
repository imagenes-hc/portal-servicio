---
import type { NewsItem } from "../lib/fetchNews";

const { source, sourceIcon, title, description, url, date } =
  Astro.props as NewsItem;

const formattedDate = new Date(date).toLocaleDateString("es-ES", {
  day: "numeric",
  month: "short",
  year: "numeric",
});
---

<a
  href={url}
  target="_blank"
  rel="noopener noreferrer"
  class="block rounded-xl border border-gray-100 bg-white p-5 shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:shadow-md"
>
  <div class="mb-2 flex items-center gap-1.5 text-xs text-gray-400">
    <span>{sourceIcon}</span>
    <span>{source}</span>
    <span>·</span>
    <time datetime={date}>{formattedDate}</time>
  </div>
  <h3
    class="mb-1.5 text-sm font-semibold leading-snug text-gray-800 line-clamp-2"
  >
    {title}
  </h3>
  <p class="text-sm leading-relaxed text-gray-500 line-clamp-2">
    {description}
  </p>
</a>
